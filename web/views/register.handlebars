<div class="auth-container">
    <div class="auth-left">
        <h2>Already a Climber?</h2>
        <p>If you already have an account, log in to continue tracking your climbing sessions and progress.</p>
        <a href="/login" class="btn-create">Login</a>
    </div>
    <div class="auth-right">
        <h2>New Here?</h2>
        <h3>Create Account</h3>
        <p>Join the community and start logging your sends.</p>
        <form method="POST" action="/register">
            <div class="form-group">
                <label for="username">Username</label>
                <input 
                    type="text" 
                    id="username" 
                    name="username" 
                    placeholder="Choose a unique username"
                    required
                    autocomplete="username"
                    minlength="3"
                    maxlength="30"
                >
            </div>
            <div class="form-group">
                <label for="email">Email Address</label>
                <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    placeholder="your.email@example.com"
                    required
                    autocomplete="email"
                >
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input 
                    type="password" 
                    id="password" 
                    name="password" 
                    placeholder="At least 6 characters"
                    required
                    autocomplete="new-password"
                    minlength="6"
                >
            </div>
            <div class="form-group">
                <label for="confirm_password">Confirm Password</label>
                <input 
                    type="password" 
                    id="confirm_password" 
                    name="confirm_password" 
                    placeholder="Re-enter your password"
                    required
                    autocomplete="new-password"
                    minlength="6"
                >
            </div>
            {{#if error}}
                <p class="error">{{error}}</p>
            {{/if}}
            <button type="submit" class="btn-login">Create Account</button>
        </form>
    </div>  
</div>