% ============ COLUMN 3 ============
\begin{column}{\colwidth}

  \begin{block}{Authentication Sequence}
    Mobile login flow, from tap to authenticated state:

    \vspace{0.1cm}
    \begin{center}
    \begin{tikzpicture}[
      font=\footnotesize,
      life/.style={draw, thick},
      msg/.style={-{Latex[length=2mm]}, thin},
      ret/.style={-{Latex[length=2mm]}, thin, dashed},
      self/.style={thin},
    ]
      % Lifeline headers
      \node (A) at (0,0)   {\textbf{Mobile App}};
      \node (B) at (4.5,0) {\textbf{Express Server}};
      \node (C) at (8.5,0) {\textbf{SQLite}};

      \draw[life] (0,-0.3)   -- (0,-9.0);
      \draw[life] (4.5,-0.3) -- (4.5,-9.0);
      \draw[life] (8.5,-0.3) -- (8.5,-9.0);

      % 1. Login request
      \draw[msg] (0,-1.0) -- node[above,font=\tiny]
        {POST /api/auth/login \{email, password\}} (4.5,-1.0);

      % 2. DB query
      \draw[msg] (4.5,-1.9) -- node[above,font=\tiny]
        {SELECT * FROM users WHERE email = ?} (8.5,-1.9);

      % 3. DB response
      \draw[ret] (8.5,-2.6) -- node[above,font=\tiny]
        {user row} (4.5,-2.6);

      % 4. bcrypt self-loop
      \draw[self] (4.5,-3.2) -- (4.8,-3.2) -- (4.8,-3.8) -- (4.5,-3.8);
      \draw[msg,self] (4.8,-3.8) -- (4.5,-3.8);
      \node[font=\tiny,align=left] at (6.3,-3.5)
        {bcrypt.compare(password, hash)};

      % 5. jwt.sign self-loop
      \draw[self] (4.5,-4.4) -- (4.8,-4.4) -- (4.8,-5.0) -- (4.5,-5.0);
      \draw[msg,self] (4.8,-5.0) -- (4.5,-5.0);
      \node[font=\tiny,align=left] at (6.5,-4.7)
        {jwt.sign(\{userId\}, secret, 7d)};

      % 6. Return token
      \draw[ret] (4.5,-5.7) -- node[above,font=\tiny]
        {\{token, user\}} (0,-5.7);

      % 7. AsyncStorage self-loop
      \draw[self] (0,-6.4) -- (-0.4,-6.4) -- (-0.4,-7.0) -- (0,-7.0);
      \draw[msg,self] (-0.4,-7.0) -- (0,-7.0);
      \node[font=\tiny,align=left] at (2.1,-6.7)
        {AsyncStorage.multiSet([token, user])};

      % 8. Navigate
      \draw[self] (0,-7.7) -- (-0.4,-7.7) -- (-0.4,-8.3) -- (0,-8.3);
      \draw[msg,self] (-0.4,-8.3) -- (0,-8.3);
      \node[font=\tiny,align=left] at (1.8,-8.0)
        {navigate to home screen};

    \end{tikzpicture}
    \end{center}
  \end{block}

  \begin{block}{Key Design Decisions}
    \heading{Session-first workflow}
    Users must start a session (with a gym name) before logging climbs.
    This reflects real climbing behaviour --- one gym visit equals one session,
    with multiple climbs beneath it. It also enables session-level statistics
    (total climbs, duration, top rate) and prevents orphaned climb records.

    \vspace{0.1cm}
    \heading{One active session per user}
    Before creating a new session the server checks for an existing row
    where \texttt{end\_time IS NULL}. If one exists, its ID is returned so the
    client can navigate directly to it. This mirrors physical reality (a climber
    cannot be at two gyms simultaneously) and prevents duplicate active sessions
    accumulating in the database.

    \vspace{0.1cm}
    \heading{Dual authentication strategy}
    The web app uses cookie sessions because browsers manage the cookie jar
    automatically. The mobile app cannot share that jar across network requests,
    so a JWT is issued on login, stored in \texttt{AsyncStorage}, and attached to
    every subsequent request as a \texttt{Bearer} token. Both strategies share
    the same user table and bcrypt password hashing.

    \vspace{0.1cm}
    \heading{Optional image uploads}
    Climb photos are nullable in the schema. This lowers the barrier to quick
    logging, accommodates gyms with photography restrictions, and reduces
    storage pressure without changing the data model.
  \end{block}

  \begin{block}{Features}
    \begin{itemize}\setlength\itemsep{2pt}
      \item User registration and login shared across web and mobile
      \item Start and end timed climbing sessions with gym name
      \item Log individual climbs: V-scale grade, attempts, topped status,
            zones reached, optional photo
      \item Public session feed visible to all users (most recent 20)
      \item Personal session history with per-session climb detail
      \item Mobile app state persisted across restarts via \texttt{AsyncStorage}
      \item Server hosted on a VPS; mobile app connects to the live endpoint
    \end{itemize}
  \end{block}

\end{column}

